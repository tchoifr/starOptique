{
  "name": "@staratlas/data-source",
  "version": "0.7.7",
  "description": "Solana account data abstraction across rpc and other sources",
  "license": "Apache-2.0",
  "main": "dist/src/index.js",
  "homepage": "https://build.staratlas.com/dev-resources/apis-and-data/data-source",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:docs": "typedoc",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "local-validator": "solana-test-validator -r",
    "type-check": "tsc --noEmit",
    "prepare": "pnpm run build && pnpm run type-check && pnpm run lint",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/staratlasmeta/data-source.git"
  },
  "files": [
    "dist",
    "src",
    "test"
  ],
  "dependencies": {
    "@noble/curves": "^1.3.0",
    "@solana/spl-token": "^0.3.7",
    "@solana/web3.js": "^1.74.0",
    "@staratlas/anchor": "^0.25.0",
    "bs58": "^5.0.0",
    "camelcase": "^7.0.0",
    "lodash": "^4.17.21",
    "neverthrow": "^6.0.0"
  },
  "devDependencies": {
    "@supercharge/promise-pool": "^3.1.0",
    "@types/bs58": "^4.0.1",
    "@types/jest": "^29.5.3",
    "@types/lodash": "^4.14.191",
    "@types/node": "^16.15.0",
    "@typescript-eslint/eslint-plugin": "^5.59.7",
    "@typescript-eslint/parser": "^5.59.7",
    "eslint": "^8.41.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.6.1",
    "jest-expect-message": "^1.1.3",
    "prettier": "^2.7.1",
    "prettier-plugin-organize-imports": "^3.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typedoc": "^0.25",
    "typescript": "^5.0.4"
  },
  "packageManager": "pnpm@9.7.1"
}
